{
  "weeks": [
    {
      "id": "week1",
      "title": "Week 1",
      "summary": "Easy warm-up questions",
  "questions": [
        {
          "id": "w1q1",
          "title": "Sum of Array",
          "difficulty": "Easy",
          "summary": "Compute the sum of all elements.",
          "description": "Given an array of integers, return the sum of all values.",
          "examples": [
            { "input": "[1, 2, 3]", "output": "6" },
            { "input": "[-5, 5, 10]", "output": "10" }
          ]
        },
        {
          "id": "w1q2",
          "title": "Maximum Element",
          "difficulty": "Easy",
          "summary": "Find the maximum value in an array.",
          "description": "Given an array of integers, return the maximum value.",
          "examples": [
            { "input": "[4, 2, 9, 1]", "output": "9" },
            { "input": "[-1, -2, -3]", "output": "-1" }
          ]
        },
        {
          "id": "w1q3",
          "title": "Count Vowels",
          "difficulty": "Easy",
          "summary": "Count vowels in a string.",
          "description": "Given a string, count how many vowels it contains.",
          "examples": [
            { "input": "\"hello\"", "output": "2" },
            { "input": "\"rhythm\"", "output": "0" }
          ]
        },
        {
          "id": "w1q4",
          "title": "Reverse String",
          "difficulty": "Easy",
          "summary": "Reverse a string.",
          "description": "Given a string, return it reversed.",
          "examples": [
            { "input": "\"abc\"", "output": "\"cba\"" },
            { "input": "\"race\"", "output": "\"ecar\"" }
          ]
        },
        {
          "id": "w1q5",
          "title": "Even or Odd Count",
          "difficulty": "Easy",
          "summary": "Count evens and odds.",
          "description": "Given an array of integers, return counts of even and odd values.",
          "examples": [
            { "input": "[1, 2, 3, 4]", "output": "even=2, odd=2" },
            { "input": "[2, 6, 8]", "output": "even=3, odd=0" }
          ]
        }
      ]
    },
    {
      "id": "week2",
      "title": "Week 2",
      "summary": "Easy array and string practice",
      "questions": [
        {
          "id": "w2q1",
          "title": "Second Largest",
          "difficulty": "Easy",
          "summary": "Find second largest element.",
          "description": "Given an array of integers, return the second largest distinct value.",
          "examples": [
            { "input": "[5, 1, 3, 4]", "output": "4" },
            { "input": "[9, 9, 7]", "output": "7" }
          ]
        },
        {
          "id": "w2q2",
          "title": "Palindrome Check",
          "difficulty": "Easy",
          "summary": "Check if string is a palindrome.",
          "description": "Given a string, return true if it reads the same forward and backward.",
          "examples": [
            { "input": "\"level\"", "output": "true" },
            { "input": "\"hello\"", "output": "false" }
          ]
        },
        {
          "id": "w2q3",
          "title": "Array Rotation",
          "difficulty": "Easy",
          "summary": "Rotate array by k.",
          "description": "Rotate an array to the right by k steps.",
          "examples": [
            { "input": "nums=[1,2,3,4], k=2", "output": "[3,4,1,2]" },
            { "input": "nums=[1], k=3", "output": "[1]" }
          ]
        },
        {
          "id": "w2q4",
          "title": "Frequency Count",
          "difficulty": "Easy",
          "summary": "Count occurrences.",
          "description": "Return a map of element frequencies.",
          "examples": [
            { "input": "[1,1,2,3,3,3]", "output": "{1:2,2:1,3:3}" },
            { "input": "[]", "output": "{}" }
          ]
        },
        {
          "id": "w2q5",
          "title": "Remove Duplicates",
          "difficulty": "Easy",
          "summary": "Remove duplicates from array.",
          "description": "Return an array with unique values in order.",
          "examples": [
            { "input": "[1,2,2,3]", "output": "[1,2,3]" },
            { "input": "[4,4,4]", "output": "[4]" }
          ]
        }
      ]
    },
    {
      "id": "week3",
      "title": "Week 3",
      "summary": "Easy to medium basics",
      "questions": [
        {
          "id": "w3q1",
      "title": "Two Sum",
          "difficulty": "Easy",
          "summary": "Find indices that sum to target.",
          "description": "Return indices of two numbers such that they add up to target.",
          "examples": [
            { "input": "nums=[2,7,11,15], target=9", "output": "[0,1]" },
            { "input": "nums=[3,2,4], target=6", "output": "[1,2]" }
          ]
        },
        {
          "id": "w3q2",
          "title": "Missing Number",
          "difficulty": "Easy",
          "summary": "Find missing number 0..n.",
          "description": "Given array containing numbers 0..n, return the missing number.",
          "examples": [
            { "input": "[3,0,1]", "output": "2" },
            { "input": "[0,1]", "output": "2" }
          ]
        },
        {
          "id": "w3q3",
          "title": "Valid Parentheses",
          "difficulty": "Easy",
          "summary": "Check bracket balance.",
          "description": "Return true if brackets are properly closed.",
          "examples": [
            { "input": "\"()[]{}\"", "output": "true" },
            { "input": "\"(]\"", "output": "false" }
          ]
        },
        {
          "id": "w3q4",
          "title": "Merge Two Sorted Lists",
          "difficulty": "Easy",
          "summary": "Merge two sorted arrays.",
          "description": "Given two sorted arrays, return a merged sorted array.",
          "examples": [
            { "input": "[1,3], [2,4]", "output": "[1,2,3,4]" },
            { "input": "[], [5]", "output": "[5]" }
          ]
        },
        {
          "id": "w3q5",
          "title": "Climbing Stairs",
          "difficulty": "Easy",
          "summary": "Count ways to climb steps.",
          "description": "Return number of distinct ways to climb n stairs (1 or 2 steps).",
          "examples": [
            { "input": "n=2", "output": "2" },
            { "input": "n=3", "output": "3" }
          ]
        }
      ]
    },
    {
      "id": "week4",
      "title": "Week 4",
      "summary": "Easy and mixed practice",
      "questions": [
        {
          "id": "w4q1",
          "title": "Anagram Check",
          "difficulty": "Easy",
          "summary": "Check if two strings are anagrams.",
          "description": "Return true if both strings contain the same letters.",
          "examples": [
            { "input": "\"listen\", \"silent\"", "output": "true" },
