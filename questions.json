        },
        {
          "id": "w4q4",
          "title": "Pair Sum",
          "difficulty": "Easy",
          "summary": "Find if any pair equals target.",
          "description": "Return true if any two numbers sum to target.",
          "examples": [
            { "input": "nums=[1,4,6], target=10", "output": "true" },
            { "input": "nums=[1,2,3], target=7", "output": "false" }
          ]
        },
        {
          "id": "w4q5",
          "title": "Running Sum",
          "difficulty": "Easy",
          "summary": "Compute prefix sums.",
          "description": "Return array where each element is the sum up to that index.",
          "examples": [
            { "input": "[1,2,3,4]", "output": "[1,3,6,10]" },
            { "input": "[5]", "output": "[5]" }
          ]
        }
      ]
    },
    {
