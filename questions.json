          ]
        },
        {
          "id": "w4q2",
          "title": "Longest Word",
          "difficulty": "Easy",
          "summary": "Find longest word in sentence.",
          "description": "Return the longest word from a sentence string.",
          "examples": [
            { "input": "\"we love coding\"", "output": "\"coding\"" },
            { "input": "\"hello world\"", "output": "\"hello\"" }
          ]
        },
        {
          "id": "w4q3",
